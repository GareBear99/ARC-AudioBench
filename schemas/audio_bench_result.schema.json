{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GareBear99/ARC-AudioBench/schemas/audio_bench_result.schema.json",
  "title": "ARC-AudioBench Result",
  "type": "object",
  "required": ["schema_version", "tool", "analysis_type", "source_file", "sha256", "sample_rate", "duration_seconds", "peak", "rms", "dc_offset", "clipping_samples", "pass"],
  "properties": {
    "schema_version": {"const": "arc-audiobench-result-v1"},
    "tool": {"const": "ARC-AudioBench"},
    "tool_version": {"type": "string"},
    "analysis_type": {"type": "string"},
    "label": {"type": "string"},
    "source_file": {"type": "string"},
    "sha256": {"type": "string", "minLength": 64, "maxLength": 64},
    "created_utc": {"type": "string"},
    "sample_rate": {"type": "integer", "minimum": 1},
    "channels": {"type": "integer", "minimum": 1},
    "sample_width_bytes": {"type": "integer", "minimum": 1},
    "frames": {"type": "integer", "minimum": 0},
    "duration_seconds": {"type": "number", "minimum": 0},
    "peak": {"type": "number", "minimum": 0},
    "rms": {"type": "number", "minimum": 0},
    "crest_factor": {"type": "number", "minimum": 0},
    "dc_offset": {"type": "number"},
    "clipping_samples": {"type": "integer", "minimum": 0},
    "dominant_frequency_estimate_hz": {"type": "number", "minimum": 0},
    "pass": {"type": "boolean"}
  }
}
